<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<StackPane style="-fx-background-color: #6e625a;" xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.cab302thursdaytbd.PetDeathController">
    <children>

        <VBox alignment="CENTER" prefHeight="480.0" prefWidth="420.0" spacing="0">

            <!-- TOP LABEL -->
            <VBox alignment="CENTER" prefHeight="40.0">
                <children>
                    <Text text="DESKTOP PET" strokeType="OUTSIDE" strokeWidth="0.0">
                        <font><Font name="Leelawadee UI Bold" size="11.0" /></font>
                        <fill><Color red="0.85" green="0.80" blue="0.75" opacity="0.7" /></fill>
                    </Text>
                </children>
            </VBox>

            <!-- TOMBSTONE IMAGE + LEVEL BADGE -->
            <StackPane prefHeight="120.0" prefWidth="120.0" maxWidth="120.0" maxHeight="120.0">
                <children>
                    <ImageView fx:id="tombstoneView" fitHeight="110.0" fitWidth="110.0"
                               pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@images/frog1.png" />
                        </image>
                    </ImageView>
                    <!-- Level badge top right -->
                    <Label fx:id="levelLabel"
                           style="-fx-background-color: #4a9eda; -fx-background-radius: 20; -fx-text-fill: white; -fx-font-family: 'Leelawadee UI Bold'; -fx-font-size: 10; -fx-padding: 2 7;"
                           text="Lvl. 1"
                           StackPane.alignment="TOP_RIGHT" />
                </children>
            </StackPane>

            <!-- SPACER -->
            <Region prefHeight="18.0" />

            <!-- YOUR PET PERISHED -->
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Your pet perished." textAlignment="CENTER">
                <font><Font name="Leelawadee UI Bold" size="22.0" /></font>
                <fill><Color red="0.94" green="0.92" blue="0.90" /></fill>
                <effect>
                    <DropShadow height="20" radius="8">
                        <color><Color red="0.3" green="0.24" blue="0.20" opacity="0.7" /></color>
                    </DropShadow>
                </effect>
            </Text>

            <!-- SPACER -->
            <Region prefHeight="16.0" />

            <!-- QUOTE CARD -->
            <VBox style="-fx-padding: 0 30 0 30;">
                <children>
                    <VBox style="-fx-background-color: #f0ebe6; -fx-background-radius: 12; -fx-padding: 16 20;">
                        <children>
                            <Label fx:id="quoteLabel"
                                   style="-fx-font-family: 'Leelawadee UI'; -fx-font-size: 12; -fx-text-fill: #5a4f49; -fx-wrap-text: true; -fx-text-alignment: center;"
                                   text="&quot;...I knocked over your water glass every morning just to see you. I would have done it forever.&quot;"
                                   wrapText="true"
                                   alignment="CENTER"
                                   maxWidth="340.0" />
                        </children>
                    </VBox>
                </children>
            </VBox>

            <!-- SPACER -->
            <Region prefHeight="16.0" />

            <!-- PET NAME + GONE TOO SOON -->
            <VBox alignment="CENTER" spacing="2.0">
                <children>
                    <Label fx:id="petNameLabel"
                           style="-fx-font-family: 'Leelawadee UI Bold'; -fx-font-size: 13; -fx-text-fill: #e8e0d8;"
                           text="Mochi" />
                    <Label style="-fx-font-family: 'Leelawadee UI'; -fx-font-size: 11; -fx-text-fill: #b8ada6;"
                           text="gone too soon" />
                </children>
            </VBox>

            <!-- SPACER -->
            <Region prefHeight="10.0" />

            <!-- REASON BADGE -->
            <StackPane>
                <children>
                    <Label fx:id="reasonLabel"
                           style="-fx-background-color: #313131; -fx-background-radius: 20; -fx-text-fill: #e8e0d8; -fx-font-family: 'Leelawadee UI'; -fx-font-size: 11; -fx-padding: 4 14;"
                           text="Reason: Neglect" />
                </children>
            </StackPane>

            <!-- SPACER -->
            <Region prefHeight="28.0" />

            <!-- BUTTONS -->
            <HBox alignment="CENTER" spacing="16.0" style="-fx-padding: 0 30 0 30;">
                <children>
                    <Button fx:id="quitButton" mnemonicParsing="false" onMouseClicked="#handleQuit"
                            style="-fx-padding: 12 0; -fx-background-color: #f0ebe6; -fx-text-fill: #2e2925; -fx-background-radius: 8; -fx-cursor: hand;"
                            text="Quit" prefWidth="160.0">
                        <font><Font name="Leelawadee UI Bold" size="15.0" /></font>
                    </Button>
                    <Button fx:id="adoptNewButton" mnemonicParsing="false" onMouseClicked="#handleAdoptNew"
                            style="-fx-padding: 12 0; -fx-background-color: #313131; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"
                            text="Adopt a new pet" prefWidth="160.0">
                        <font><Font name="Leelawadee UI Bold" size="15.0" /></font>
                    </Button>
                </children>
            </HBox>

        </VBox>

    </children>
</StackPane>


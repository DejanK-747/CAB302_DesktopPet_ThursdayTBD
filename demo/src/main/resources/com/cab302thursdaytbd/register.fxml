<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.cab302thursdaytbd.RegisterController">

    <VBox spacing="10"
          alignment="CENTER"
          style="-fx-padding: 20">

        <ImageView fitWidth="100" fitHeight="100" preserveRatio="true">
            <image>
                <Image url="@images/Frog%20excited%201.png"/>
            </image>
        </ImageView>

        <Label text="Sign-up" style="-fx-font-size: 18px;"/>

        <TextField fx:id="usernameField"
                   promptText="Username"
                   maxWidth="200"/>
        <PasswordField fx:id="passwordField"
                       promptText="Password"
                       maxWidth="200"/>
        <PasswordField fx:id="confirmPasswordField"
                       promptText="Confirm Password"
                       maxWidth="200"/>

        <Button text="Create Account"
                onAction="#handleRegister"
                maxWidth="200"/>

        <Label fx:id="statusLabel"/>

        </VBox>
    <Button text="Back to Login"
            StackPane.alignment="TOP_LEFT"
            onAction="#goToLogin"
            style="-fx-padding: 5; -fx-font-size: 9px;"
            maxWidth="70"/>
</StackPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane style="-fx-background-color: #6e625a;" xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.cab302thursdaytbd.PetStatsController">
   <children>

      <VBox prefHeight="480.0" prefWidth="420.0" spacing="0">

         <!-- TOP BAR: back arrow + title -->
         <HBox alignment="CENTER_LEFT" prefHeight="55.0" prefWidth="420.0"
               style="-fx-padding: 0 20 0 16;">
            <children>
               <Label onMouseClicked="#handleBack" style="-fx-font-size: 22; -fx-text-fill: #f0ebe6; -fx-cursor: hand;" text="‹" />
               <Region HBox.hgrow="ALWAYS" />
               <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Stats" textAlignment="CENTER">
                  <font>
                     <Font name="Leelawadee UI Bold" size="18.0" />
                  </font>
                  <fill><Color red="0.94" green="0.92" blue="0.9" /></fill>
                  <effect>
                     <DropShadow height="20" radius="8">
                        <color>
                           <Color red="0.36" green="0.3" blue="0.26" opacity="0.6" />
                        </color>
                     </DropShadow>
                  </effect>
               </Text>
               <Region HBox.hgrow="ALWAYS" />
               <!-- Spacer to balance the back arrow -->
               <Label style="-fx-font-size: 22; -fx-text-fill: transparent;" text="‹" />
            </children>
         </HBox>

         <!-- PET CARD -->
         <VBox style="-fx-padding: 0 20 0 20;">
            <children>
               <HBox alignment="CENTER_LEFT" spacing="14"
                     style="-fx-background-color: #f0ebe6; -fx-background-radius: 14; -fx-padding: 14 16;">
                  <children>
                     <!-- Pet image thumbnail -->
                     <StackPane style="-fx-background-color: #ddd7d2; -fx-background-radius: 10;"
                                minWidth="70" minHeight="70" maxWidth="70" maxHeight="70">
                        <children>
                           <ImageView fx:id="petView" fitHeight="60.0" fitWidth="60.0"
                                      pickOnBounds="true" preserveRatio="true">
                              <image>
                                 <Image url="@images/frog1.png" />
                              </image>
                           </ImageView>
                        </children>
                     </StackPane>

                     <VBox alignment="CENTER_LEFT" spacing="4">
                        <children>
                           <!-- Name + Level badge row -->
                           <HBox alignment="CENTER_LEFT" spacing="8">
                              <children>
                                 <Label fx:id="nameLabel" style="-fx-font-family: 'Leelawadee UI Bold'; -fx-font-size: 18; -fx-text-fill: #2e2925;" text="Pet Name" />
                                 <Label fx:id="levelLabel" style="-fx-background-color: #4a9eda; -fx-background-radius: 20; -fx-text-fill: white; -fx-font-family: 'Leelawadee UI Bold'; -fx-font-size: 11; -fx-padding: 2 8;" text="Lvl. 1" />
                              </children>
                           </HBox>
                           <!-- Mood line -->
                           <HBox alignment="CENTER_LEFT" spacing="4">
                              <children>
                                 <Label style="-fx-font-family: 'Leelawadee UI'; -fx-font-size: 13; -fx-text-fill: #7a6f69;" text="Mood: " />
                                 <Label fx:id="moodLabel" style="-fx-font-family: 'Leelawadee UI'; -fx-font-size: 13; -fx-text-fill: #7a6f69;" text="Happy" />
                              </children>
                           </HBox>
                        </children>
                     </VBox>
                  </children>
               </HBox>
            </children>
         </VBox>

         <!-- SPACER -->
         <Region prefHeight="14" />

         <!-- MOST COMMON MOOD SECTION -->
         <VBox style="-fx-padding: 0 20 0 20;" spacing="8">
            <children>
               <Label style="-fx-font-family: 'Leelawadee UI Bold'; -fx-font-size: 13; -fx-text-fill: #f0ebe6;" text="Most common mood">
                  <effect>
                     <DropShadow height="14" radius="5">
                        <color><Color red="0.36" green="0.3" blue="0.26" opacity="0.5" /></color>
                     </DropShadow>
                  </effect>
               </Label>

               <HBox alignment="CENTER_LEFT" spacing="12"
                     style="-fx-background-color: #f0ebe6; -fx-background-radius: 12; -fx-padding: 12 16;">
                  <children>
                     <!-- Mood emoji circle -->
                     <StackPane style="-fx-background-color: #e4ddd8; -fx-background-radius: 50;"
                                minWidth="38" minHeight="38" maxWidth="38" maxHeight="38">
                        <children>
                           <Label fx:id="commonMoodEmojiLabel" style="-fx-font-size: 18;" text="😊" />
                        </children>
                     </StackPane>

                     <VBox alignment="CENTER_LEFT" spacing="2">
                        <children>
                           <Label fx:id="commonMoodLabel" style="-fx-font-family: 'Leelawadee UI Bold'; -fx-font-size: 14; -fx-text-fill: #2e2925;" text="Happy" />
                           <Label fx:id="commonMoodDescLabel" style="-fx-font-family: 'Leelawadee UI'; -fx-font-size: 12; -fx-text-fill: #7a6f69;" text="Feeling playful and content" />
                        </children>
                     </VBox>
                  </children>
               </HBox>
            </children>
         </VBox>

         <!-- SPACER -->
         <Region prefHeight="14" />

         <!-- STATISTICS SECTION -->
         <VBox style="-fx-padding: 0 20 0 20;" spacing="10">
            <children>
               <Label style="-fx-font-family: 'Leelawadee UI Bold'; -fx-font-size: 13; -fx-text-fill: #f0ebe6;" text="Statistics">
                  <effect>
                     <DropShadow height="14" radius="5">
                        <color><Color red="0.36" green="0.3" blue="0.26" opacity="0.5" /></color>
                     </DropShadow>
                  </effect>
               </Label>

               <!-- Hunger -->
               <VBox spacing="4">
                  <children>
                     <HBox>
                        <children>
                           <Label style="-fx-font-family: 'Leelawadee UI Bold'; -fx-font-size: 12; -fx-text-fill: #f0ebe6;" text="Hunger" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label fx:id="hungerPctLabel" style="-fx-font-family: 'Leelawadee UI'; -fx-font-size: 12; -fx-text-fill: #c9bfb8;" text="0%" />
                        </children>
                     </HBox>
                     <ProgressBar fx:id="hungerBar" prefWidth="380" prefHeight="10"
                                  style="-fx-accent: #c8a882; -fx-background-color: #4a3f39; -fx-background-radius: 6; -fx-control-inner-background: #4a3f39; -fx-border-radius: 6;"
                                  progress="0.72" />
                  </children>
               </VBox>

               <!-- Energy -->
               <VBox spacing="4">
                  <children>
                     <HBox>
                        <children>
                           <Label style="-fx-font-family: 'Leelawadee UI Bold'; -fx-font-size: 12; -fx-text-fill: #f0ebe6;" text="Energy" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label fx:id="energyPctLabel" style="-fx-font-family: 'Leelawadee UI'; -fx-font-size: 12; -fx-text-fill: #c9bfb8;" text="0%" />
                        </children>
                     </HBox>
                     <ProgressBar fx:id="energyBar" prefWidth="380" prefHeight="10"
                                  style="-fx-accent: #6b9e7a; -fx-background-color: #4a3f39; -fx-background-radius: 6; -fx-control-inner-background: #4a3f39; -fx-border-radius: 6;"
                                  progress="0.55" />
                  </children>
               </VBox>

               <!-- Affection -->
               <VBox spacing="4">
                  <children>
                     <HBox>
                        <children>
                           <Label style="-fx-font-family: 'Leelawadee UI Bold'; -fx-font-size: 12; -fx-text-fill: #f0ebe6;" text="Affection" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label fx:id="affectionPctLabel" style="-fx-font-family: 'Leelawadee UI'; -fx-font-size: 12; -fx-text-fill: #c9bfb8;" text="0%" />
                        </children>
                     </HBox>
                     <ProgressBar fx:id="affectionBar" prefWidth="380" prefHeight="10"
                                  style="-fx-accent: #c87a9e; -fx-background-color: #4a3f39; -fx-background-radius: 6; -fx-control-inner-background: #4a3f39; -fx-border-radius: 6;"
                                  progress="0.88" />
                  </children>
               </VBox>

               <!-- Boredom -->
               <VBox spacing="4">
                  <children>
                     <HBox>
                        <children>
                           <Label style="-fx-font-family: 'Leelawadee UI Bold'; -fx-font-size: 12; -fx-text-fill: #f0ebe6;" text="Boredom" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Label fx:id="boredomPctLabel" style="-fx-font-family: 'Leelawadee UI'; -fx-font-size: 12; -fx-text-fill: #c9bfb8;" text="0%" />
                        </children>
                     </HBox>
                     <ProgressBar fx:id="boredomBar" prefWidth="380" prefHeight="10"
                                  style="-fx-accent: #8a7a5a; -fx-background-color: #4a3f39; -fx-background-radius: 6; -fx-control-inner-background: #4a3f39; -fx-border-radius: 6;"
                                  progress="0.30" />
                  </children>
               </VBox>

            </children>
         </VBox>

      </VBox>

   </children>
</StackPane>

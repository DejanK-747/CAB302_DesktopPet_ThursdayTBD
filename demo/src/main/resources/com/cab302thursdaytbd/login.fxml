<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="12" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.cab302thursdaytbd.LoginController">

    <ImageView fitHeight="100" fitWidth="100" preserveRatio="true">
        <image>
            <Image url="@images/frog1.png" />
        </image>
    </ImageView>

    <Label style="-fx-font-size: 18px;" text="Login" />

    <TextField fx:id="usernameField" maxWidth="200" promptText="Username" />

    <PasswordField fx:id="passwordField" maxWidth="200" promptText="Password" />

    <Button maxWidth="200" onAction="#handleLogin" text="Login" />
    <Button maxWidth="200" onAction="#goToRegister" text="Create Account" />

    <Label maxWidth="200" style="-fx-font-size: 11px; -fx-text-fill: grey;" text="Don’t have an account? Create one to get started" wrapText="true" />

    <Label fx:id="statusLabel" textFill="red" />

</VBox>

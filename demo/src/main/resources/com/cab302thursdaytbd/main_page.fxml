<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cab302thursdaytbd.MainPageController">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="480.0" prefWidth="420.0">
         <children>
            <GridPane alignment="CENTER" prefHeight="61.0" prefWidth="420.0" style="-fx-background-color: #ebe1c5;">
              <columnConstraints>
                <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Text fx:id="petName" strokeType="OUTSIDE" strokeWidth="0.0" text="PET NAME" textAlignment="CENTER">
                     <font>
                        <Font name="Leelawadee UI Bold" size="16.0" />
                     </font>
                  </Text>
                  <Button fx:id="menuButton" mnemonicParsing="false" onMouseClicked="#onMenuClick" prefHeight="33.0" prefWidth="90.0" style="-fx-background-color: #313131; -fx-text-fill: white;" text="MENU" GridPane.columnIndex="1">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Button>
                  <Text fx:id="levelText" layoutX="40.0" layoutY="47.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Mood: " textAlignment="CENTER" GridPane.columnIndex="2">
                     <font>
                        <Font name="Leelawadee UI Bold" size="16.0" />
                     </font>
                  </Text>
               </children>
            </GridPane>
            <AnchorPane prefHeight="418.0" prefWidth="420.0">
               <children>
                  <Pane fx:id="pane" prefHeight="418.0" prefWidth="420.0">
                     <children>
                        <ImageView fitHeight="453.0" fitWidth="420.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/background/pixel-night-sky-square.png" />
                           </image>
                        </ImageView>
                     </children>
                  </Pane>
                  <GridPane layoutX="19.0" layoutY="10.0" prefHeight="68.0" prefWidth="372.0" style="-fx-background-color: #94918a; -fx-opacity: 90%;">
                    <columnConstraints>
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0">
                           <children>
                              <ImageView fitHeight="26.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@images/icons/hunger.png" />
                                 </image>
                                 <HBox.margin>
                                    <Insets left="10.0" />
                                 </HBox.margin>
                              </ImageView>
                              <ProgressBar fx:id="hungerBar" prefHeight="18.0" prefWidth="107.0" progress="0.35">
                                 <HBox.margin>
                                    <Insets left="10.0" />
                                 </HBox.margin>
                              </ProgressBar>
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" layoutX="10.0" layoutY="10.0" prefHeight="100.0" prefWidth="200.0" GridPane.columnIndex="1">
                           <children>
                              <ImageView fitHeight="26.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@images/icons/affection.png" />
                                 </image>
                                 <HBox.margin>
                                    <Insets left="10.0" />
                                 </HBox.margin>
                              </ImageView>
                              <ProgressBar fx:id="affectionBar" prefHeight="18.0" prefWidth="107.0" progress="0.0">
                                 <HBox.margin>
                                    <Insets left="10.0" />
                                 </HBox.margin>
                              </ProgressBar>
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" layoutX="10.0" layoutY="10.0" prefHeight="100.0" prefWidth="200.0" GridPane.rowIndex="1">
                           <children>
                              <ImageView fitHeight="26.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@images/icons/cleanliness.png" />
                                 </image>
                                 <HBox.margin>
                                    <Insets left="10.0" />
                                 </HBox.margin>
                              </ImageView>
                              <ProgressBar fx:id="energyBar" prefHeight="18.0" prefWidth="107.0" progress="0.0">
                                 <HBox.margin>
                                    <Insets left="10.0" />
                                 </HBox.margin>
                              </ProgressBar>
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" layoutX="10.0" layoutY="40.0" prefHeight="100.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                           <children>
                              <ImageView fitHeight="26.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@images/icons/cross.png" />
                                 </image>
                                 <HBox.margin>
                                    <Insets left="10.0" />
                                 </HBox.margin>
                              </ImageView>
                              <ProgressBar fx:id="boredomBar" prefHeight="18.0" prefWidth="107.0" progress="0.35">
                                 <HBox.margin>
                                    <Insets left="10.0" />
                                 </HBox.margin>
                              </ProgressBar>
                           </children></HBox>
                     </children>
                  </GridPane>
                  <GridPane layoutX="10.0" layoutY="370.0">
                    <columnConstraints>
                      <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                      <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                           <Button fx:id="foodButton" mnemonicParsing="false" onMouseClicked="#showFoodPopUp">
                           <graphic>
                              <ImageView fx:id="foodIcon" fitHeight="52.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@images/icons/fork_and_knife.png" />
                                 </image>
                              </ImageView>
                           </graphic>
                        </Button>
                        <Button fx:id="brushButton" layoutX="35.0" layoutY="4.0" mnemonicParsing="false" onMouseClicked="#brushPet" GridPane.columnIndex="1">
                           <graphic>
                              <ImageView fx:id="energyIcon" fitHeight="52.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@images/icons/brush.png" />
                                 </image>
                              </ImageView>
                           </graphic>
                        </Button>
                        <Button fx:id="chatButton" layoutX="35.0" layoutY="4.0" mnemonicParsing="false" onAction="#handleGoChatButtonAction" onMouseClicked="#petSpeech" GridPane.columnIndex="2">
                           <graphic>
                              <ImageView fitHeight="52.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@images/icons/chat.png" />
                                 </image>
                              </ImageView>
                           </graphic>
                        </Button>
                        <Button fx:id="strokeButton" layoutX="35.0" layoutY="4.0" mnemonicParsing="false" onMouseClicked="#strokePet" GridPane.columnIndex="3">
                           <graphic>
                              <ImageView  fx:id="attentionIcon" fitHeight="52.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@images/icons/hand.png" />
                                 </image>
                              </ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </GridPane>
                  <Label fx:id="statusChangeLabel" layoutX="275.0" layoutY="160.0" opacity="0.0" style="-fx-background-color: #ffcd29;" text="STAUS CHANGE">
                     <font>
                        <Font name="Leelawadee UI Semilight" size="15.0" />
                     </font>
                  </Label>
                  <Label fx:id="needsLabel"
                         alignment="CENTER"
                         layoutX="110.0"
                         layoutY="90.0"
                         prefHeight="30.0"
                         prefWidth="200.0"
                         style="-fx-background-color: #ff6b6b; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold;"
                         text="Your pet needs something!"
                         visible="false">
                     </Label>
               </children>
            </AnchorPane>
         </children>
      </VBox>
      <Pane fx:id="speechPane" layoutX="40.0" layoutY="170.0" opacity="0.0">
         <children>
            <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/speech_bubble.png" />
               </image>
            </ImageView>
            <Label layoutX="46.0" layoutY="24.0" text="Text goes here!">
               <font>
                  <Font name="Leelawadee UI Bold" size="15.0" />
               </font>
            </Label>
         </children>
      </Pane>
      <Pane fx:id="petPane" layoutX="135.0" layoutY="235.0" maxHeight="133.0" maxWidth="137.0" minHeight="-Infinity" minWidth="-Infinity" prefHeight="133.0" prefWidth="137.0">
         <children>
            <ImageView fx:id="petView" fitHeight="133.0" fitWidth="137.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/frog1.png" />
               </image>
            </ImageView>
         </children>
      </Pane>
      <Pane fx:id="foodPopUp" layoutX="106.0" layoutY="365.0" minHeight="-Infinity" minWidth="-Infinity" prefHeight="50.0" prefWidth="186.0" scaleX="0.0" scaleY="0.0" style="-fx-background-color: aliceblue;">
         <children>
            <ImageView fx:id="bananaView" fitHeight="40.0" fitWidth="39.0" layoutY="6.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/food/banana.png" />
               </image>
            </ImageView>
            <ImageView fx:id="grasshopperView" fitHeight="40.0" fitWidth="39.0" layoutX="47.0" layoutY="6.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/food/grasshopper.png" />
               </image>
            </ImageView>
            <ImageView fx:id="mysteriousLiquidView" fitHeight="43.0" fitWidth="51.0" layoutX="93.0" layoutY="4.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/food/mysteriousLiquid.png" />
               </image>
            </ImageView>
            <ImageView fx:id="biscuitView" fitHeight="39.0" fitWidth="39.0" layoutX="137.0" layoutY="6.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/food/biscuit.png" />
               </image>
            </ImageView>
         </children>
      </Pane>
   </children>
</AnchorPane>
